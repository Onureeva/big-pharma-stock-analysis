        "ax.set_ylabel(\"Volatility (% points)\")\n",
        "ax.legend(loc=\"best\")\n",
        "for s, e in spans:\n",
        "    s_dt, e_dt = pd.to_datetime(s), pd.to_datetime(e)\n",
