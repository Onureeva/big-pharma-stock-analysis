        "]\n",
        "\n",
        "events = [\n",
        "    \"2023-08-08\",\n",
        "    \"2024-08-08\",\n",
        "    \"2025-08-07\",\n",
        "    \"2025-03-24\",\n",
        "]\n",
        "\n",
        "# Plotting\n",
        "fig, ax = plt.subplots(figsize=(12, 6))\n",
        "ax.plot(rolling_vol_lly.index, rolling_vol_lly.values, label=\"LLY\", lw=2, color=\"#1f77b4\")\n",
