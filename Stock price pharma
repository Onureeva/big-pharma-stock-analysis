      "cell_type": "code",
      "source": [
        "!pip install yfinance --quiet\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import yfinance as yf\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from datetime import datetime\n",
        "import warnings\n",
        "from IPython.display import display\n",
        "\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "sns.set_style(\"whitegrid\")\n",
        "sns.set_context(\"talk\")\n",
        "\n",
        "USER_AGENT = \"Olga Nureeva onureeva@umass.edu\"\n",
        "headers = {\"User-Agent\": USER_AGENT}\n",
        "ticker = \"LLY\"\n",
        "def get_cik_for_ticker(ticker_symbol):\n",
        "    url = \"https://www.sec.gov/files/company_tickers.json\"\n",
        "    r = requests.get(url, headers=headers)\n",
        "    r.raise_for_status()\n",
        "    data = r.json()\n",
        "    rows = []\n",
        "    for v in data.values():\n",
        "        rows.append({\"ticker\": v[\"ticker\"], \"title\": v[\"title\"], \"cik\": str(v[\"cik_str\"])})\n",
        "    df = pd.DataFrame(rows)\n",
        "    row = df[df[\"ticker\"].str.upper() == ticker_symbol.upper()]\n",
        "    if row.empty:\n",
        "        return None\n",
        "    return row.iloc[0][\"cik\"].zfill(10)\n",
        "\n",
        "cik = get_cik_for_ticker(ticker)\n",
        "if cik is None:\n",
        "    raise SystemExit(f\"CIK для {ticker} не найден.\")\n",
        "print(\"CIK:\", cik)\n",
        "\n",
        "# Downloading companyfacts JSON\n",
        "facts_url = f\"https://data.sec.gov/api/xbrl/companyfacts/CIK{cik}.json\"\n",
        "print(\"Downloading companyfacts from:\", facts_url)\n",
        "r = requests.get(facts_url, headers=headers)\n",
        "r.raise_for_status()\n",
        "facts = r.json()\n",
        "\n",
        "#Extract year companyfacts\n",
        "def extract_annual_from_companyfacts(facts_json, tag_candidates, prefer_unit=\"USD\"):\n",
        "    usgaap = facts_json.get(\"facts\", {}).get(\"us-gaap\", {})\n",
        "    chosen_tag = None\n",
        "    results = []\n",
        "    for tag in tag_candidates:\n",
        "        if tag not in usgaap:\n",
        "            continue\n",
        "        chosen_tag = tag\n",
        "        concept = usgaap[tag]\n",
        "        units = concept.get(\"units\", {})\n",
        "        unit_to_use = prefer_unit if prefer_unit in units else (list(units.keys())[0] if units else None)\n",
        "        if unit_to_use is None:\n",
        "            continue\n",
        "        facts_list = units.get(unit_to_use, [])\n",
        "        for f in facts_list:\n",
        "            end = f.get(\"end\")\n",
        "            val = f.get(\"val\")\n",
        "            form = f.get(\"form\", \"\")\n",
        "            fp = f.get(\"fp\", \"\")\n",
        "            if end is None or val is None:\n",
        "                continue\n",
        "            try:\n",
        "                valf = float(val)\n",
        "            except Exception:\n",
        "                try:\n",
        "                    valf = float(str(val).replace(\",\", \"\"))\n",
        "                except Exception:\n",
        "                    continue\n",
        "            results.append({\"end\": end, \"value\": valf, \"unit\": unit_to_use, \"form\": form, \"fp\": fp})\n",
        "        break\n",
        "    if chosen_tag is None or not results:\n",
        "        return pd.DataFrame(), None\n",
        "    df = pd.DataFrame(results)\n",
        "    df[\"end_dt\"] = pd.to_datetime(df[\"end\"]).dt.tz_localize(None)\n",
        "    out_rows = []\n",
        "    for year, g in df.groupby(df[\"end_dt\"].dt.year):\n",
        "        g = g.copy()\n",
        "        g[\"priority\"] = g[\"form\"].str.contains(\"10-K\", na=False).astype(int)*2 + (g[\"fp\"] == \"FY\").astype(int)\n",
        "        g = g.sort_values(by=[\"priority\",\"end_dt\"], ascending=[False, False])\n",
        "        sel = g.iloc[0]\n",
        "        out_rows.append({\"year\": int(year), \"end_dt\": sel[\"end_dt\"], \"value\": sel[\"value\"], \"unit\": sel[\"unit\"], \"form\": sel[\"form\"]})\n",
        "    out = pd.DataFrame(out_rows).sort_values(\"end_dt\").reset_index(drop=True)\n",
        "    return out, chosen_tag\n",
        "\n",
        "# Candidate tags\n",
        "revenue_tags = [\"Revenues\", \"SalesRevenueNet\", \"RevenuesNetOfInterestExpense\", \"RevenueFromContractWithCustomerExcludingAssessedTax\"]\n",
        "net_income_tags = [\"NetIncomeLoss\", \"ProfitLoss\", \"NetIncomeLossAvailableToCommonStockholdersBasic\"]\n",
        "dividend_tags = [\"DividendsPaid\", \"DividendsDeclared\", \"CommonStockDividendsPerShareDeclared\", \"DividendsPerShareDeclared\"]\n",
        "\n",
        "rev_df, rev_tag = extract_annual_from_companyfacts(facts, revenue_tags)\n",
        "ni_df, ni_tag = extract_annual_from_companyfacts(facts, net_income_tags)\n",
        "div_df, div_tag = extract_annual_from_companyfacts(facts, dividend_tags)\n",
        "\n",
        "print(\"Detected concepts:\", {\"revenue\": rev_tag, \"net_income\": ni_tag, \"dividend\": div_tag})\n",
        "print(\"Revenue rows:\\n\", rev_df)\n",
        "print(\"Net income rows:\\n\", ni_df)\n",
        "print(\"Dividend rows:\\n\", div_df)\n",
        "\n",
        "# Fallback through yfinance\n",
        "if rev_df.empty and ni_df.empty and div_df.empty:\n",
        "    print(\"SEC data пусты, используем yfinance как fallback.\")\n",
        "    yf_t = yf.Ticker(ticker)\n",
        "    try:\n",
        "        divs = yf_t.dividends\n",
        "        if isinstance(divs, pd.Series) and not divs.empty:\n",
        "            divs_by_year = divs.groupby(divs.index.year).sum().reset_index()\n",
        "            div_df = pd.DataFrame({\n",
        "                \"year\": divs_by_year.iloc[:,0].astype(int),\n",
        "                \"end_dt\": pd.to_datetime(divs_by_year.iloc[:,0].astype(str) + \"-12-31\"),\n",
        "                \"value\": divs_by_year.iloc[:,1],\n",
        "                \"unit\":\"USD\",\n",
        "                \"form\":\"dividends_yfinance\"\n",
        "            })\n",
        "            print(\"Dividends (yfinance):\")\n",
        "            print(div_df)\n",
        "    except Exception as e:\n",
        "        print(\"yfinance fallback error:\", e)\n",
        "\n",
        "#Merge datasets:\n",
        "dfs = []\n",
        "if not rev_df.empty:\n",
        "    dfs.append(rev_df[[\"end_dt\",\"value\"]].rename(columns={\"value\":\"revenue\"}))\n",
        "if not ni_df.empty:\n",
        "    dfs.append(ni_df[[\"end_dt\",\"value\"]].rename(columns={\"value\":\"net_income\"}))\n",
        "if not div_df.empty:\n",
        "    dfs.append(div_df[[\"end_dt\",\"value\"]].rename(columns={\"value\":\"dividend\"}))\n",
        "\n",
        "if not dfs:\n",
        "    raise SystemExit(\"Нет данных по выручке/чистой прибыли/дивидендам ни в SEC, ни в fallback.\")\n",
        "\n",
        "merged = dfs[0]\n",
        "for d in dfs[1:]:\n",
        "    merged = pd.merge(merged, d, on=\"end_dt\", how=\"outer\")\n",
        "merged = merged.sort_values(\"end_dt\").reset_index(drop=True)\n",
        "merged[\"year\"] = merged[\"end_dt\"].dt.year\n",
        "merged[\"dividend\"] = merged.get(\"dividend\", pd.Series([0]*len(merged))).fillna(0)\n",
        "print(\"\\nMerged financials:\")\n",
        "display(merged)\n",
        "\n",
        "#Downloading price:\n",
        "yf_ticker = yf.Ticker(ticker)\n",
        "start_fetch = merged[\"end_dt\"].min() - pd.Timedelta(days=30)\n",
        "end_fetch   = merged[\"end_dt\"].max() + pd.Timedelta(days=30)\n",
        "\n",
        "hist = yf_ticker.history(\n",
        "    start=start_fetch.strftime(\"%Y-%m-%d\"),\n",
        "    end=(end_fetch + pd.Timedelta(days=1)).strftime(\"%Y-%m-%d\"),\n",
        "    auto_adjust=False\n",
        ")\n",
        "if hist.empty:\n",
        "    raise SystemExit(\"Unable to download through yfinance.\")\n",
        "\n",
        "hist.index = pd.to_datetime(hist.index)\n",
        "try:\n",
        "    if hist.index.tz is not None:\n",
        "        hist.index = hist.index.tz_convert(\"UTC\").tz_localize(None)\n",
        "except Exception:\n",
        "    try:\n",
        "        hist.index = hist.index.tz_localize(None)\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "price_col = \"Adj Close\" if \"Adj Close\" in hist.columns else (\"Close\" if \"Close\" in hist.columns else hist.columns[0])\n",
        "price_series = hist[price_col].copy()\n",
        "merged[\"end_dt\"] = pd.to_datetime(merged[\"end_dt\"]).dt.tz_localize(None)\n",
        "\n",
        "try:\n",
        "    reindexed = price_series.reindex(pd.DatetimeIndex(merged[\"end_dt\"]), method=\"ffill\")\n",
        "    merged[\"stock_price\"] = reindexed.values\n",
        "except Exception:\n",
        "    prices = []\n",
        "    for ed in merged[\"end_dt\"]:\n",
        "        prior = hist[hist.index <= ed]\n",
        "        if not prior.empty:\n",
        "            p = prior.iloc[-1][price_col]\n",
        "        else:\n",
        "            after = hist[hist.index >= ed]\n",
        "            p = after.iloc[0][price_col] if not after.empty else np.nan\n",
        "        prices.append(float(p) if not pd.isna(p) else np.nan)\n",
        "    merged[\"stock_price\"] = prices\n",
        "\n",
        "print(\"\\nMerged with stock prices:\")\n",
        "display(merged)\n",
        "\n",
        "# Vizulization:\n",
        "fig, ax1 = plt.subplots(figsize=(12,6))\n",
        "x = np.arange(len(merged))\n",
        "width = 0.25\n",
        "\n",
        "rev_vals = merged[\"revenue\"].fillna(0).astype(float) / 1e9\n",
        "ni_vals = merged[\"net_income\"].fillna(0).astype(float) / 1e9\n",
        "div_vals = merged[\"dividend\"].fillna(0).astype(float) / 1e9\n",
        "\n",
        "ax1.bar(x - width, rev_vals, width=width, label=\"Revenue (USD, bn)\", color=\"#4C72B0\")\n",
        "ax1.bar(x, ni_vals, width=width, label=\"Net Income (USD, bn)\", color=\"#55A868\")\n",
        "ax1.bar(x + width, div_vals, width=width, label=\"Dividends (USD, bn)\", color=\"#C44E52\")\n",
        "\n",
        "ax1.set_ylabel(\"USD (billion)\")\n",
        "ax1.set_xticks(x)\n",
        "ax1.set_xticklabels(merged[\"year\"].astype(str), rotation=45)\n",
        "\n",
        "ax2 = ax1.twinx()\n",
        "ax2.plot(x, merged[\"stock_price\"], color=\"black\", marker=\"o\", label=f\"{ticker} Price (USD)\", linewidth=2)\n",
        "ax2.set_ylabel(\"Stock price (USD)\")\n",
        "\n",
        "lines1, labels1 = ax1.get_legend_handles_labels()\n",
        "lines2, labels2 = ax2.get_legend_handles_labels()\n",
        "ax1.legend(lines1 + lines2, labels1 + labels2, loc='best')\n",
        "\n",
        "plt.title(f\"{ticker}: Revenue / Net Income / Dividends vs Stock Price by Fiscal Year End\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nFinal table:\")\n",
        "display(merged[[\"year\",\"end_dt\",\"revenue\",\"net_income\",\"dividend\",\"stock_price\"]])\n"
      ],
